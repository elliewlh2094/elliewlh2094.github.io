---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { getPageMeta } from '../lib/site/metadata';
import '../styles/global.css';

const pageMeta = getPageMeta(Astro.props);
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageMeta.description} />
    {pageMeta.noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={pageMeta.pageTitle} />
    <meta property="og:description" content={pageMeta.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content={pageMeta.siteName} />
    <title>{pageMeta.pageTitle}</title>
  </head>
  <body>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
