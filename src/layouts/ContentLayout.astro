---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  dateLabel?: string;
  updatedDateLabel?: string;
  eyebrow?: string;
}

const { title, description, dateLabel, updatedDateLabel, eyebrow = 'Article' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="content-page">
    <header class="content-hero">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p>{description}</p>
      <div class="content-meta">
        {dateLabel && <time>{dateLabel}</time>}
        {updatedDateLabel && <span>更新：{updatedDateLabel}</span>}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
