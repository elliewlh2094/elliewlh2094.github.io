---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const formattedDate = post.data.pubDate.toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="article-card">
  <a class="article-cover-link" href={`/blog/${post.id}/`} aria-label={`閱讀文章：${post.data.title}`}>
    {
      post.data.cover ? (
        <img src={post.data.cover} alt={`${post.data.title} 文章封面`} loading="lazy" />
      ) : (
        <span class="lab-cover" aria-hidden="true">
          <strong>{post.data.title}</strong>
        </span>
      )
    }
  </a>
  <div class="article-card-body">
    <div class="article-card-topline">
      <p class="article-date">{formattedDate}</p>
    </div>
    <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
    <p>{post.data.description}</p>
  </div>
</article>
