---
import type { ArticleCardData } from '../lib/content/blog';

interface Props {
  post: ArticleCardData;
}

const { post } = Astro.props;
---

<article class="article-card">
  <a class="article-cover-link" href={post.href} aria-label={`閱讀文章：${post.title}`}>
    {
      post.cover ? (
        <img src={post.cover.src} alt={post.cover.alt} loading="lazy" />
      ) : (
        <span class="article-cover-placeholder" aria-hidden="true"></span>
      )
    }
  </a>
  <div class="article-card-body">
    <div class="article-card-topline">
      <p class="article-date">{post.formattedDate}</p>
    </div>
    <h3><a href={post.href}>{post.title}</a></h3>
    <p>{post.description}</p>
  </div>
</article>
