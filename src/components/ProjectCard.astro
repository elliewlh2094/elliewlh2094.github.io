---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<article class="project-card">
  <a class="project-cover-link" href={`/projects/${project.id}/`} aria-label={`閱讀專案：${project.data.title}`}>
    {
      project.data.cover ? (
        <img src={project.data.cover} alt={`${project.data.title} 專案封面`} loading="lazy" />
      ) : (
        <span class="lab-cover" aria-hidden="true">
          <strong>{project.data.title}</strong>
        </span>
      )
    }
  </a>
  <div class="project-card-body">
    <h3><a href={`/projects/${project.id}/`}>{project.data.title}</a></h3>
    <p>{project.data.description}</p>
    <dl class="meta-list">
      <div>
        <dt>角色</dt>
        <dd>{project.data.role}</dd>
      </div>
      <div>
        <dt>時間</dt>
        <dd>{project.data.period}</dd>
      </div>
    </dl>
    {
      project.data.highlights.length > 0 && (
        <ul class="highlight-list">
          {project.data.highlights.slice(0, 3).map((highlight) => (
            <li>{highlight}</li>
          ))}
        </ul>
      )
    }
  </div>
</article>
