---
import type { ProjectCardData } from '../lib/content/projects';

interface Props {
  project: ProjectCardData;
}

const { project } = Astro.props;
---

<article class="project-card">
  <a class="project-cover-link" href={project.href} aria-label={`閱讀專案：${project.title}`}>
    {
      project.cover ? (
        <img src={project.cover.src} alt={project.cover.alt} loading="lazy" />
      ) : (
        <span class="lab-cover" aria-hidden="true">
          <strong>{project.title}</strong>
        </span>
      )
    }
  </a>
  <div class="project-card-body">
    <h3><a href={project.href}>{project.title}</a></h3>
    <p>{project.description}</p>
    <dl class="meta-list">
      <div>
        <dt>閱讀時間</dt>
        <dd>{project.readingTime}</dd>
      </div>
    </dl>
  </div>
</article>
