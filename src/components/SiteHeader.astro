---
import { NAV_ITEMS, SITE_NAME } from '../lib/site/config';
---

<header class="site-header">
  <a class="brand" href="/" aria-label="回到首頁">
    <span class="brand-mark">ERN</span>
    <span>{SITE_NAME}</span>
  </a>
  <nav class="site-nav" aria-label="主要導覽">
    {NAV_ITEMS.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>
