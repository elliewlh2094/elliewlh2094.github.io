---
import { render } from 'astro:content';
import {
  getPublishedProjectPaths,
  toProjectPageData
} from '../../lib/content/projects';
import ContentLayout from '../../layouts/ContentLayout.astro';

export async function getStaticPaths() {
  return getPublishedProjectPaths();
}

const { project } = Astro.props;
const { Content } = await render(project);
const page = toProjectPageData(project);
---

<ContentLayout
  title={page.title}
  description={page.description}
  eyebrow="Project Note"
>
  {
    page.cover && (
      <img class="content-cover" src={page.cover.src} alt={page.cover.alt} />
    )
  }
  <section class="project-summary" aria-label="專案摘要">
    <div>
      <span>閱讀時間</span>
      <strong>{page.readingTime}</strong>
    </div>
    <div>
      <span>重點摘要</span>
      <ul class="summary-copy">
        {page.summary.map((summary) => <li>{summary}</li>)}
      </ul>
    </div>
  </section>
  <div class="link-row">
    {page.repo && <a class="button secondary" href={page.repo} target="_blank" rel="noreferrer">查看程式碼</a>}
    {page.demo && <a class="button primary" href={page.demo} target="_blank" rel="noreferrer">查看展示</a>}
  </div>
  <Content />
</ContentLayout>
