---
import { getCollection, render } from 'astro:content';
import { toBlogPageData } from '../lib/content/blog';
import { toProjectPageData } from '../lib/content/projects';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await getCollection('blog');
const projects = await getCollection('projects');

const blogDemo = posts.find((post) => post.id === '00-longform-style-demo');
const projectDemo = projects.find((project) => project.id === '00-longform-style-demo-project');

if (!blogDemo || !projectDemo) {
  throw new Error('Longform demo content is missing.');
}

const { Content: BlogContent } = await render(blogDemo);
const { Content: ProjectContent } = await render(projectDemo);
const blogPage = toBlogPageData(blogDemo);
const projectPage = toProjectPageData(projectDemo);
---

<BaseLayout
  title="長篇內容排版展示"
  description="展示草稿文章與草稿專案在長篇內容下的版面效果。"
  noindex
>
  <article class="content-page">
    <header class="content-hero">
      <p class="eyebrow">Longform Demo</p>
      <h1>長篇內容排版展示</h1>
      <p>這個頁面用來檢查草稿文章與草稿專案在長篇內容下的閱讀版面，不會加入網站導覽。</p>
    </header>

    <section class="prose" aria-labelledby="blog-demo-title">
      <p class="eyebrow">Blog 範例</p>
      <h2 id="blog-demo-title">{blogPage.title}</h2>
      <p>{blogPage.description}</p>
      {
        blogPage.cover ? (
          <img class="content-cover" src={blogPage.cover.src} alt={blogPage.cover.alt} />
        ) : (
          <div class="content-cover article-cover-placeholder" aria-hidden="true"></div>
        )
      }
      <BlogContent />
    </section>

    <section class="prose longform-demo-section" aria-labelledby="project-demo-title">
      <p class="eyebrow">Project 範例</p>
      <h2 id="project-demo-title">{projectPage.title}</h2>
      <p>{projectPage.description}</p>
      {
        projectPage.cover && (
          <img class="content-cover" src={projectPage.cover.src} alt={projectPage.cover.alt} />
        )
      }
      <section class="project-summary" aria-label="專案摘要">
        <div>
          <span>閱讀時間</span>
          <strong>{projectPage.readingTime}</strong>
        </div>
        <div>
          <span>重點摘要</span>
          <ul class="summary-copy">
            {projectPage.summary.map((summary) => <li>{summary}</li>)}
          </ul>
        </div>
      </section>
      <ProjectContent />
    </section>
  </article>
</BaseLayout>
