---
import { render } from 'astro:content';
import {
  getPublishedPostPaths,
  toBlogPageData
} from '../../lib/content/blog';
import ContentLayout from '../../layouts/ContentLayout.astro';

export async function getStaticPaths() {
  return getPublishedPostPaths();
}

const { post } = Astro.props;
const { Content } = await render(post);
const page = toBlogPageData(post);
---

<ContentLayout
  title={page.title}
  description={page.description}
  dateLabel={page.formattedDate}
  updatedDateLabel={page.formattedUpdatedDate}
  eyebrow="Blog Post"
>
  {
    page.cover && (
      <img class="content-cover" src={page.cover.src} alt={page.cover.alt} />
    )
  }
  <Content />
</ContentLayout>
