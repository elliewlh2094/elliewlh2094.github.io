---
import ArticleCard from '../../components/ArticleCard.astro';
import { getPublishedPosts, toArticleCardData } from '../../lib/content/blog';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getPublishedPosts()).map(toArticleCardData);
---

<BaseLayout title="文章" description="Ellie 的 AI 工具實作、機器人視覺、遊戲與手作筆記。">
  <section class="page-heading">
    <p class="eyebrow">Blog</p>
    <h1>部落格</h1>
    <p>文章會收集 AI 工具實作、機器人視覺文獻觀察、遊戲心得與手作紀錄。內容可以慢慢補圖、補參考資料與補反思。</p>
  </section>
  <section class="section">
    <div class="article-grid">
      {posts.map((post) => <ArticleCard post={post} />)}
    </div>
  </section>
</BaseLayout>
