---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('projects'))
  .filter((project) => !project.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
const featuredProjects = projects.filter((project) => project.data.featured).slice(0, 3);
const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft && post.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Ellie's Robot Notebook">
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">Robot Lab Notes</p>
      <h1>Ellie's Robot Notebook</h1>
      <p>
        這是 Ellie Huang 的機器人探索筆記，從我的研究到副專案，再到 AI 與生活心得。
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/projects/">查看專案</a>
        <a class="button secondary" href="/blog/">閱讀文章</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Featured Experiments</p>
      <h2>研究與副專案</h2>
      <p>先放兩個最能代表目前方向的專案：一個是機器人系統研究，一個是開源視覺化工具。</p>
    </div>
    <div class="project-grid home-card-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="section-actions">
      <a class="button secondary" href="/projects/">查看更多</a>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Notebook Index</p>
      <h2>文章與筆記</h2>
      <p>
        文章會混合研究筆記、工具製作、遊戲心得與手作紀錄。每篇文章都是一個 Markdown 檔案，方便持續補圖、補實驗與補想法。
      </p>
    </div>
    <div class="article-mini-grid home-card-grid">
      {posts.map((post) => <ArticleCard post={post} />)}
    </div>
    <div class="section-actions">
      <a class="button secondary" href="/blog/">查看更多</a>
    </div>
  </section>
</BaseLayout>
