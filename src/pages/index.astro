---
import ArticleCard from '../components/ArticleCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getFeaturedPosts, toArticleCardData } from '../lib/content/blog';
import { getFeaturedProjects, toProjectCardData } from '../lib/content/projects';
import BaseLayout from '../layouts/BaseLayout.astro';

const featuredProjectCards = (await getFeaturedProjects()).map(toProjectCardData);
const featuredPostCards = (await getFeaturedPosts()).map(toArticleCardData);
---

<BaseLayout title="Ellie's Robot Notebook">
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">Robot Notes</p>
      <h1>Ellie's Robot Notebook</h1>
      <p>
        這是我的機器人探索筆記，從研究到 side project 再到一點點生活紀錄。
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/projects/">查看專案</a>
        <a class="button secondary" href="/blog/">閱讀文章</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Pinned Projects</p>
      <h2>置頂專案</h2>
      <p>
        這裡是我近期做的專案。
      </p>
    </div>
    <div class="project-grid home-card-grid">
      {featuredProjectCards.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="section-actions">
      <a class="button secondary" href="/projects/">查看更多</a>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Blog</p>
      <h2>部落格</h2>
      <p>
        這裡會放一些比較隨意寫寫的文章。
      </p>
    </div>
    <div class="article-mini-grid home-card-grid">
      {featuredPostCards.map((post) => <ArticleCard post={post} />)}
    </div>
    <div class="section-actions">
      <a class="button secondary" href="/blog/">查看更多</a>
    </div>
  </section>
</BaseLayout>
